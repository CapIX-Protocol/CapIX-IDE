{
  "name": "capix-llm",
  "displayName": "Capix LLM",
  "description": "Deploy and manage LLM endpoints on the Capix GPU network \u2014 right from the IDE.",
  "version": "2.3.2",
  "publisher": "capix",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "icon": "resources/capix-icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "capix-cloud",
          "title": "Capix Cloud",
          "icon": "resources/icon-cloud.svg"
        },
        {
          "id": "capix-intelligence",
          "title": "Intelligence",
          "icon": "resources/icon-brain.svg"
        },
        {
          "id": "capix-code",
          "title": "Capix Code",
          "icon": "resources/icon-code.svg"
        }
      ]
    },
    "views": {
      "capix-cloud": [
        {
          "id": "capix.cloud.overview",
          "name": "Cloud",
          "type": "webview"
        },
        {
          "id": "capix.llm.profile",
          "name": "Profile",
          "type": "webview"
        },
        {
          "id": "capix.llm.deploys",
          "name": "My Deploys"
        },
        {
          "id": "capix.llm.instances",
          "name": "Instances"
        },
        {
          "id": "capix.llm.jobs",
          "name": "Serverless Jobs"
        },
        {
          "id": "capix.llm.apikeys",
          "name": "API Keys"
        },
        {
          "id": "capix.llm.catalog",
          "name": "Model Catalog"
        },
        {
          "id": "capix.llm.hosted",
          "name": "Ready Now (Hosted)"
        },
        {
          "id": "capix.cloud.resource",
          "name": "Resource",
          "type": "webview"
        }
      ],
      "capix-intelligence": [
        {
          "id": "capix.intelligence.panel",
          "name": "Intelligence",
          "type": "webview"
        },
        {
          "id": "capix.llm.agents",
          "name": "Agents"
        }
      ],
      "capix-code": [
        {
          "id": "capix.code.chat",
          "name": "Capix Code",
          "type": "webview"
        },
        {
          "id": "capix.orchestration.view",
          "name": "Orchestration"
        },
        {
          "id": "capix.agentTimeline.view",
          "name": "Agent Timeline"
        },
        {
          "id": "capix.agentDebugger.view",
          "name": "Agent Debugger"
        }
      ]
    },
    "commands": [
      {
        "command": "capix.edits.preview",
        "title": "Capix: Preview Pending Edits",
        "icon": "$(diff)"
      },
      {
        "command": "capix.launchCentre",
        "title": "Capix: Open Launch Centre",
        "icon": "$(rocket)"
      },
      {
        "command": "capix.deployModel",
        "title": "Capix: Deploy LLM\u2026",
        "icon": "$(rocket)"
      },
      {
        "command": "capix.deployCustomModel",
        "title": "Capix: Deploy Custom Model (Hugging Face link)\u2026",
        "icon": "$(add)"
      },
      {
        "command": "capix.destroyDeploy",
        "title": "Capix: Destroy Deploy",
        "icon": "$(trash)"
      },
      {
        "command": "capix.stopDeploy",
        "title": "Capix: Stop Deploy",
        "icon": "$(debug-stop)"
      },
      {
        "command": "capix.startDeploy",
        "title": "Capix: Start Deploy",
        "icon": "$(debug-start)"
      },
      {
        "command": "capix.viewLogs",
        "title": "Capix: View Deploy Logs",
        "icon": "$(output)"
      },
      {
        "command": "capix.copyEndpoint",
        "title": "Capix: Copy Endpoint URL"
      },
      {
        "command": "capix.copyApiKey",
        "title": "Capix: Copy API Key"
      },
      {
        "command": "capix.refreshDeploys",
        "title": "Capix: Refresh Deploys",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.refreshCatalog",
        "title": "Capix: Refresh Catalog",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.openConsole",
        "title": "Capix: Open Web Console",
        "icon": "$(link-external)"
      },
      {
        "command": "capix.intelligence.openPanel",
        "title": "Capix: Open Intelligence",
        "icon": "$(sparkle)"
      },
      {
        "command": "capix.webControl.openPanel",
        "title": "Capix: Open Web Control",
        "icon": "$(globe)"
      },
      {
        "command": "capix.infra.openPanel",
        "title": "Capix: Open Infrastructure",
        "icon": "$(server-environment)"
      },
      {
        "command": "capix.infra.architectPlan",
        "title": "Capix: Architect Mode \u2014 Plan Infra\u2026",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "capix.connectWallet",
        "title": "Capix: Sign In"
      },
      {
        "command": "capix.resetSessionAndSignIn",
        "title": "Capix: Reset Session and Sign In"
      },
      {
        "command": "capix.execOnInstance",
        "title": "Capix: Run Command on GPU Instance\u2026",
        "icon": "$(terminal)"
      },
      {
        "command": "capix.topUp",
        "title": "Capix: Top Up Wallet Balance\u2026",
        "icon": "$(credit-card)"
      },
      {
        "command": "capix.refreshProfile",
        "title": "Capix: Refresh Profile",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.openBilling",
        "title": "Capix: Open Billing Page",
        "icon": "$(link-external)"
      },
      {
        "command": "capix.openInstance",
        "title": "Capix: Open Instance Detail",
        "icon": "$(link)"
      },
      {
        "command": "capix.openTerminal",
        "title": "Capix: Open SSH Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "capix.downloadSshKey",
        "title": "Capix: Download SSH Key\u2026",
        "icon": "$(key)"
      },
      {
        "command": "capix.refreshInstances",
        "title": "Capix: Refresh Instances",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.refreshAgents",
        "title": "Capix: Refresh Agents",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.refreshJobs",
        "title": "Capix: Refresh Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.refreshApiKeys",
        "title": "Capix: Refresh API Keys",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.deployAgent",
        "title": "Capix: Deploy Agent (GitHub repo)\u2026",
        "icon": "$(github)"
      },
      {
        "command": "capix.triggerJob",
        "title": "Capix: Trigger Serverless Job\u2026",
        "icon": "$(play)"
      },
      {
        "command": "capix.createApiKey",
        "title": "Capix: Create API Key\u2026",
        "icon": "$(add)"
      },
      {
        "command": "capix.covenantEdit",
        "title": "Capix: Edit Covenant (Spirit Prompt)",
        "icon": "$(edit)"
      },
      {
        "command": "capix.covenantRemember",
        "title": "Capix: Remember (Save to Memory)\u2026"
      },
      {
        "command": "capix.covenantClear",
        "title": "Capix: Clear All Memory"
      },
      {
        "command": "capix.launchCapixCode",
        "title": "Capix: Launch Capix Code (CLI Assistant)",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "capix.setRouteMode",
        "title": "Capix: Set Routing Mode (Auto / Private / Loop)\u2026"
      },
      {
        "command": "capix.deployPrivateLlm",
        "title": "Capix: Deploy Private LLM (Uncensored)\u2026",
        "icon": "$(shield)"
      },
      {
        "command": "capix.destroyPrivateLlm",
        "title": "Capix: Destroy Private LLM (Stop Billing)",
        "icon": "$(trash)"
      },
      {
        "command": "capix.routerMemory",
        "title": "Capix: Show Smart Router Memory"
      },
      {
        "command": "capix.routerReset",
        "title": "Capix: Reset Smart Router Memory"
      },
      {
        "command": "capix.routerBlockModel",
        "title": "Capix: Block Model (Never Suggest)\u2026"
      },
      {
        "command": "capix.routerFavorModel",
        "title": "Capix: Favor Model (Always Prefer)\u2026"
      },
      {
        "command": "capix.setLayout",
        "title": "Capix: Switch Layout\u2026",
        "icon": "$(layout)"
      },
      {
        "command": "capix.cloud.deploy",
        "title": "Capix: New Cloud Resource\u2026",
        "icon": "$(add)"
      },
      {
        "command": "capix.cloud.create.vm",
        "title": "Capix: New Virtual Machine\u2026",
        "icon": "$(vm)"
      },
      {
        "command": "capix.cloud.create.gpu",
        "title": "Capix: New Dedicated GPU\u2026",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "capix.cloud.create.model",
        "title": "Capix: New Private Model\u2026",
        "icon": "$(shield)"
      },
      {
        "command": "capix.cloud.create.container",
        "title": "Capix: New Container Service\u2026",
        "icon": "$(package)"
      },
      {
        "command": "capix.cloud.create.website",
        "title": "Capix: New Website\u2026",
        "icon": "$(globe)"
      },
      {
        "command": "capix.cloud.create.job",
        "title": "Capix: New Serverless Job\u2026",
        "icon": "$(zap)"
      },
      {
        "command": "capix.cloud.resource.open",
        "title": "Capix: Open Resource Details",
        "icon": "$(server)"
      },
      {
        "command": "capix.runOn",
        "title": "Capix: Run on\u2026",
        "icon": "$(device-desktop)"
      },
      {
        "command": "capix.code.newSession",
        "title": "Capix Code: New Session",
        "icon": "$(add)"
      },
      {
        "command": "capix.code.focus",
        "title": "Capix Code: Focus Panel",
        "icon": "$(chrome-maximize)"
      },
      {
        "command": "capix.code.acceptAll",
        "title": "Capix Code: Accept All Changes",
        "icon": "$(check)"
      },
      {
        "command": "capix.code.revertAll",
        "title": "Capix Code: Revert All Changes",
        "icon": "$(discard)"
      },
      {
        "command": "capix.code.checkpoint",
        "title": "Capix Code: Create Checkpoint",
        "icon": "$(save)"
      },
      {
        "command": "capix.code.cancel",
        "title": "Capix Code: Cancel Agent",
        "icon": "$(debug-stop)"
      },
      {
        "command": "capix.setDestination",
        "title": "Capix: Switch Destination\u2026"
      },
      {
        "command": "capix.onboarding",
        "title": "Capix: Open Onboarding",
        "icon": "$(rocket)"
      },
      {
        "command": "capix.selectModel",
        "title": "Capix: Select Model\u2026",
        "icon": "$(hub)"
      },
      {
        "command": "capix.inlineCompletion.toggle",
        "title": "Capix: Toggle Inline Code Completion",
        "icon": "$(symbol-snippet)"
      },
      {
        "command": "capix.inlineCompletion.accept",
        "title": "Capix: Accept Inline Suggestion"
      },
      {
        "command": "capix.inlineCompletion.reject",
        "title": "Capix: Dismiss Inline Suggestion"
      }
    ],
    "keybindings": [
      {
        "command": "capix.inlineCompletion.accept",
        "key": "tab",
        "when": "inlineSuggestionVisible && capix.inlineCompletion.enabled && !editorTabMovesFocus"
      },
      {
        "command": "capix.inlineCompletion.reject",
        "key": "escape",
        "when": "inlineSuggestionVisible && capix.inlineCompletion.enabled"
      },
      {
        "command": "capix.inlineCompletion.toggle",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "capix.deployModel",
          "when": "view == capix.llm.catalog",
          "group": "navigation"
        },
        {
          "command": "capix.deployCustomModel",
          "when": "view == capix.llm.catalog",
          "group": "navigation"
        },
        {
          "command": "capix.refreshCatalog",
          "when": "view == capix.llm.catalog",
          "group": "navigation"
        },
        {
          "command": "capix.refreshDeploys",
          "when": "view == capix.llm.deploys",
          "group": "navigation@1"
        },
        {
          "command": "capix.setRouteMode",
          "when": "view == capix.llm.deploys",
          "group": "navigation@2"
        },
        {
          "command": "capix.deployPrivateLlm",
          "when": "view == capix.llm.deploys",
          "group": "navigation@3"
        },
        {
          "command": "capix.destroyPrivateLlm",
          "when": "view == capix.llm.deploys && capix.privateLlmActive",
          "group": "navigation@4"
        },
        {
          "command": "capix.routerMemory",
          "when": "view == capix.llm.deploys",
          "group": "navigation@5"
        },
        {
          "command": "capix.launchCapixCode",
          "when": "view == capix.llm.deploys",
          "group": "navigation@6"
        },
        {
          "command": "capix.refreshInstances",
          "when": "view == capix.llm.instances",
          "group": "navigation"
        },
        {
          "command": "capix.refreshAgents",
          "when": "view == capix.llm.agents",
          "group": "navigation"
        },
        {
          "command": "capix.refreshJobs",
          "when": "view == capix.llm.jobs",
          "group": "navigation"
        },
        {
          "command": "capix.refreshApiKeys",
          "when": "view == capix.llm.apikeys",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "capix.destroyDeploy",
          "when": "viewItem == capix-deploy",
          "group": "inline"
        },
        {
          "command": "capix.stopDeploy",
          "when": "viewItem == capix-deploy-running",
          "group": "inline"
        },
        {
          "command": "capix.startDeploy",
          "when": "viewItem == capix-deploy-stopped",
          "group": "inline"
        },
        {
          "command": "capix.viewLogs",
          "when": "viewItem =~ /^capix-deploy/",
          "group": "inline"
        },
        {
          "command": "capix.copyEndpoint",
          "when": "viewItem =~ /^capix-deploy/"
        },
        {
          "command": "capix.copyApiKey",
          "when": "viewItem =~ /^capix-deploy/"
        },
        {
          "command": "capix.execOnInstance",
          "when": "viewItem =~ /^capix-deploy/"
        },
        {
          "command": "capix.destroyDeploy",
          "when": "viewItem =~ /^capix-deploy/"
        },
        {
          "command": "capix.openTerminal",
          "when": "viewItem =~ /^capix-instance/ || viewItem =~ /^capix-agent/ || viewItem =~ /^capix-job/",
          "group": "inline"
        },
        {
          "command": "capix.downloadSshKey",
          "when": "viewItem =~ /^capix-instance/",
          "group": "inline"
        },
        {
          "command": "capix.routerBlockModel",
          "when": "viewItem == capix-model"
        },
        {
          "command": "capix.routerFavorModel",
          "when": "viewItem == capix-model"
        }
      ]
    },
    "configuration": {
      "title": "Capix LLM",
      "properties": {
        "capix.autoRefreshSeconds": {
          "type": "number",
          "default": 30,
          "description": "How often to auto-refresh deploy statuses (seconds). Set to 0 to disable."
        },
        "capix.routeMode": {
          "type": "string",
          "enum": [
            "auto",
            "private",
            "loop"
          ],
          "default": "auto",
          "description": "Smart router mode: 'auto' (dynamic model selection), 'private' (use deployed private LLM), 'loop' (private + continuous build until done)."
        },
        "capix.ai.preferredProvider": {
          "type": "string",
          "enum": [
            "auto",
            "usepod",
            "openrouter",
            "surplus"
          ],
          "enumDescriptions": [
            "Mix OpenRouter and UsePod with automatic price-aware failover.",
            "Prefer UsePod, then fall back to another enabled route.",
            "Prefer OpenRouter, then fall back to another enabled route.",
            "Prefer Surplus when the route is enabled; currently paused in production."
          ],
          "default": "auto",
          "description": "Preferred inference route. This is a preference, never a hard lock; Capix falls back when unavailable."
        },
        "capix.ai.preferredModel": {
          "type": "string",
          "default": "",
          "description": "Preferred model used by Capix Auto. Leave empty for task-aware model selection."
        },
        "capix.enableCrashReporting": {
          "type": "boolean",
          "default": false,
          "description": "Enable opt-in crash reporting"
        },
        "capix.inlineCompletion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Capix inline code completion (Copilot-style ghost text). Accept with Tab, dismiss with Escape."
        },
        "capix.inlineCompletion.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "How long to wait after the last keystroke before requesting an inline completion (milliseconds)."
        }
      }
    },
    "themes": [
      {
        "label": "Capix Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/capix-dark.json",
        "id": "capix-dark"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "eslint --fix src/"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
