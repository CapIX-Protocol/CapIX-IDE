  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#64748b", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#14F195" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#FFAE00" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#3DCED6" }
    },
    {
      "scope": ["keyword.control", "keyword.operator.expression"],
      "settings": { "foreground": "#a78bfa" }
    },
    {
      "scope": ["variable", "meta.definition.variable"],
      "settings": { "foreground": "#f1efe9" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#94a3b8" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#3DCED6" }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#14F195" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#3DCED6" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FFAE00" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#94a3b8" }
    },
    {
      "scope": ["meta.import", "meta.export"],
      "settings": { "foreground": "#94a3b8" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#3DCED6", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#f1efe9", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#94a3b8", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": { "foreground": "#14F195" }
    },
    {
      "scope": ["entity.name.selector", "meta.selector"],
      "settings": { "foreground": "#3DCED6" }
    },
    {
      "scope": ["text.html"],
      "settings": { "foreground": "#f1efe9" }
    },
    {
      "scope": ["meta.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#94a3b8" }
    }
  ]
}
