{
  "name": "capix-agent-ui",
  "displayName": "Capix Code",
  "description": "Native Capix Code sessions, routed models, coding tools and approvals inside CapixIDE.",
  "version": "1.0.0",
  "publisher": "capix",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "capix-code": [
        {
          "id": "capix.agent.sessions",
          "name": "Agent Sessions"
        },
        {
          "id": "capix.agent.chat",
          "name": "Capix Code",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "capix.agent.refreshSessions",
        "title": "Capix: Refresh Agent Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "capix.agent.openChat",
        "title": "Capix: Open Capix Code",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "capix.agent.startSession",
        "title": "Capix: Start Agent Session\u2026",
        "icon": "$(add)"
      },
      {
        "command": "capix.agent.resumeSession",
        "title": "Capix: Resume Agent Session",
        "icon": "$(debug-start)"
      },
      {
        "command": "capix.agent.selectModel",
        "title": "Capix: Select Model\u2026",
        "icon": "$(symbol-method)"
      },
      {
        "command": "capix.agent.cancel",
        "title": "Capix: Cancel Stream",
        "icon": "$(debug-stop)"
      },
      {
        "command": "capix.agent.listSessions",
        "title": "Capix: List Agent Sessions",
        "category": "Capix Agent"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "capix.agent.startSession",
          "when": "view == capix.agent.sessions",
          "group": "navigation@1"
        },
        {
          "command": "capix.agent.refreshSessions",
          "when": "view == capix.agent.sessions",
          "group": "navigation@2"
        },
        {
          "command": "capix.agent.cancel",
          "when": "view == capix.agent.chat",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "capix.agent.resumeSession",
          "when": "viewItem == capix-agent-session",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.9.3"
  },
  "extensionDependencies": [
    "capix.capix-llm"
  ]
}
