diff --git a/src/vs/workbench/contrib/void/browser/void.contribution.ts b/src/vs/workbench/contrib/void/browser/void.contribution.ts
index 35c8918..e9d1f94 100644
--- a/src/vs/workbench/contrib/void/browser/void.contribution.ts
+++ b/src/vs/workbench/contrib/void/browser/void.contribution.ts
@@ -83,3 +83,30 @@ import '../common/voidUpdateService.js'
 
 // model service
 import '../common/voidModelService.js'
+
+// CapixIDE owns the routed chat configuration. The built-in Capix extension
+// supplies a short-lived OAuth access token after native sign-in; this command
+// persists it through the encrypted application storage service and selects the
+// router's stable `auto` model. No portal API key or provider credential is
+// copied into workspace/user JSON.
+import { CommandsRegistry } from '../../../../platform/commands/common/commands.js';
+import { IVoidSettingsService } from '../common/voidSettingsService.js';
+
+CommandsRegistry.registerCommand('capix.chat.configure', async (accessor, credential: unknown, endpoint?: unknown, model?: unknown) => {
+	if (typeof credential !== 'string' || credential.length < 8) {
+		throw new Error('Capix chat configuration requires a valid credential.');
+	}
+	const routed = endpoint === undefined;
+	const selectedEndpoint = routed ? 'https://www.capix.network/api/v1' : String(endpoint).replace(/\/$/, '');
+	const selectedModel = routed ? 'auto' : String(model || 'auto');
+	const parsedEndpoint = new URL(selectedEndpoint);
+	if (parsedEndpoint.protocol !== 'https:') throw new Error('Capix chat endpoints must use HTTPS.');
+
+	const settings = accessor.get(IVoidSettingsService);
+	await settings.waitForInitState;
+	await settings.setSettingOfProvider('openAICompatible', 'endpoint', selectedEndpoint);
+	await settings.setSettingOfProvider('openAICompatible', 'apiKey', credential);
+	await settings.setSettingOfProvider('openAICompatible', 'headersJSON', '{}');
+	settings.addModel('openAICompatible', selectedModel);
+	await settings.setModelSelectionOfFeature('Chat', { providerName: 'openAICompatible', modelName: selectedModel });
+});
