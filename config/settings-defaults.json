      "note": "Paste the Base URL + API key from your LLM deploy at capix.network/cloud/llm"
    }
  },
  "capix.ai.chat.model": "",
  "capix.ai.autocomplete.enabled": true,
  "capix.ai.autocomplete.model": "",
  "capix.inlineCompletion.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "workbench.secondarySideBar.defaultVisibility": "visible",
  "workbench.editor.tabSizing": "shrink",
  "editor.minimap.enabled": false,
  "workbench.colorTheme": "Capix Dark",
  "chat.editor.fontSize": 13,
  "github.copilot.advanced": { "debug.overrideChatEngine": "disabled" },
  "telemetry.telemetryLevel": "off",
  "telemetry.feedback.enabled": false
