{
  "//": "CapixIDE default AI provider settings. Applied on first launch if the user has no existing settings.json. Users override anything here in Settings → AI.",
  "capix.ai.enabled": true,
  "capix.ai.defaultProvider": "capix",
  "capix.ai.providers": {
    "capix": {
      "label": "Capix (self-hosted endpoint)",
      "enabled": true,
      "openAICompatible": true,
      "baseURL": "",
